{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/upload/video", "dest": "/api/upload.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/analyze/stream", "dest": "/api/analyze.js" },
    { "src": "/api/generate-chapters", "dest": "/api/generate-chapters.js" },
    { "src": "/api/summarize", "dest": "/api/chat.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
